    "queue:adulte":         {"priorite": 3, "description": "Collecte Adultes (Paul/Sofia)"},
    "queue:traduction":     {"priorite": 4, "description": "Traduction (Ibrahim)"},
    "queue:correction_docs":{"priorite": 4, "description": "Correction documents (Lucas)"},
    "queue:anonymisation":  {"priorite": 5, "description": "Anonymisation (Inès)"},
    "queue:instruction":    {"priorite": 6, "description": "Instruction (Camille)"},
    "queue:scoring":        {"priorite": 7, "description": "Scoring RAG (Maya)"},
    "queue:relances":       {"priorite": 8, "description": "Relances (Mathilde)", "cron": "toutes_1h"}
  }
