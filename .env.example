# ─────────────────────────────────────────────────────────────────────────────
# MDPH-Backbone — Fichier de configuration d'environnement
# Copiez ce fichier en ".env" et renseignez vos vraies valeurs.
# NE JAMAIS committer le fichier .env en Git.
# ─────────────────────────────────────────────────────────────────────────────

# --- OpenAI ---
OPENAI_API_KEY=sk-...votre_cle_openai...
OPENAI_MODEL=gpt-4o
OPENAI_ANONYMIZER_MODEL=gpt-4o-mini

# --- WhatsApp Business Cloud API (Meta Developer Console) ---
WHATSAPP_API_TOKEN=EAAxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_VERIFY_TOKEN=mdph_verify_secret

# --- Application ---
APP_ENV=development
APP_SECRET_KEY=changeme-en-production-avec-une-cle-forte
LOG_LEVEL=INFO

# --- Base de données (future migration) ---
DATABASE_URL=sqlite:///./mdph_dossiers.db
